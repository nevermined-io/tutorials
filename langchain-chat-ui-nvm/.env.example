# ---------------------------------------------------------------------------
# Nevermined x402 — server-side only
# ---------------------------------------------------------------------------

# Your personal Nevermined API key (do NOT prefix with NEXT_PUBLIC_ —
# this must stay server-side). Generated at https://nevermined.app under
# Settings → API Keys.
NVM_API_KEY=

# The organization id the widget session will be scoped to. You must be
# an active member of this org. Find it under Settings → Organizations on
# nevermined.app, or via `payments.organizations.getMyMemberships()`.
NVM_ORG_ID=

# Nevermined environment: sandbox | live | staging_sandbox | staging_live
# Defaults to "sandbox" when unset. Determines both the backend URL the
# server hits (`/api/v1/widgets/session/self`) and the frontend host the
# popup opens (`/embed/cards/setup`).
NVM_ENVIRONMENT=sandbox

# ---------------------------------------------------------------------------
# LangGraph backend (Sprint 3 agent — proxied through /api/*)
# ---------------------------------------------------------------------------

# The LangSmith Deployment / `langgraph dev` URL of the gated agent. The
# Next.js catch-all proxy at /api/* forwards browser requests here while
# injecting payment-signature from a httpOnly cookie. Do NOT prefix this
# with NEXT_PUBLIC_ — server-side only.
LANGGRAPH_API_URL=http://127.0.0.1:2024

# ---------------------------------------------------------------------------
# Chat-UI (browser-visible)
# ---------------------------------------------------------------------------

# Tell the LangGraph SDK to talk to our local proxy at /api, NOT directly
# to the agent. The proxy is what injects payment-signature.
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Graph / assistant id served by the Sprint 3 agent. Defaults to "echo"
# in ~/code/tutorials/langchain-langsmith-deployment-py/langgraph.json.
NEXT_PUBLIC_ASSISTANT_ID=echo

# Leave blank for local dev — the upstream chat UI uses this for
# LangSmith Deployment Agent Builder auth, which is out of scope here.
NEXT_PUBLIC_AUTH_SCHEME=
