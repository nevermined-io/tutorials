# --- Nevermined credentials (sandbox) ---------------------------------------
NVM_API_KEY=your-nevermined-api-key
NVM_ENVIRONMENT=sandbox

# --- Plan that gates the agent ----------------------------------------------
# Get a plan_id from https://nevermined.app (Catalog -> Plans).
NVM_PLAN_ID=plan-...
NVM_CREDITS_PER_INVOKE=1

# --- Buyer config -----------------------------------------------------------
LANGSMITH_DEPLOYMENT_URL=http://127.0.0.1:2024
ASSISTANT_ID=echo
INPUT=hello from the buyer

# --- LangSmith Observability (optional) -------------------------------------
# Set LANGSMITH_TRACING=true and LANGSMITH_API_KEY=... to emit the Sprint 1
# nvm:verify / nvm:settlement spans into a LangSmith project.
LANGSMITH_TRACING=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
# Regional override - https://eu.api.smith.langchain.com for GCP EU accounts.
LANGSMITH_ENDPOINT=
